# Shopify app credentials (from Partner Dashboard)
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# Your app's public URL (update after deploying)
SHOPIFY_APP_URL=https://your-app-url.com

# Scopes required
SCOPES=read_products,read_product_listings

# Optional: custom shop domain
# SHOP_CUSTOM_DOMAIN=your-custom-domain.com

